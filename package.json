{
  "name": "mcp-automation-framework",
  "version": "2.0.0",
  "main": "agents/executor.ts",
  "description": "AI-driven test automation framework using natural language prompts with Playwright MCP",
  "keywords": [
    "automation",
    "testing",
    "playwright",
    "mcp",
    "ai",
    "natural-language",
    "configuration-driven",
    "cross-browser",
    "enterprise"
  ],
  "homepage": "https://github.com/your-org/mcp-automation-framework#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/mcp-automation-framework.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/mcp-automation-framework/issues"
  },
  "license": "MIT",
  "author": "Your Organization",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "build": "tsc agents/executor.ts --outDir dist",
    "executor": "ts-node agents/executor.ts",
    "regression": "ts-node agents/executor.ts",
    "regression:dev": "ts-node agents/executor.ts",
    "mcp:smoke": "node agents/real-executor.js --headed=false --suite=smoke",
    "mcp:regression": "node agents/real-executor.js --headed=false --browsers=chromium,firefox,webkit",
    "mcp:all": "node agents/real-executor.js --headed=false",
    "mcp:file": "node agents/real-executor.js --headed=false --file=",
    "mcp:headed": "node agents/real-executor.js --headed=true --file=",
    "mcp:headed:all": "node agents/real-executor.js --headed=true",
    "mcp:browser": "node agents/real-executor.js --headed=false --browser=",
    "mcp:parallel": "node agents/real-executor.js --headed=false --parallel --browsers=chromium,firefox,webkit",
    "mcp:addCandidate": "node agents/real-executor.js --headed=false --file=addCandidate.txt",
    "mcp:debug": "node agents/real-executor.js --headed=true --verbose --file=",
    "heal:smoke": "node agents/self-healing-executor.js --headed=false --suite=smoke",
    "heal:regression": "node agents/self-healing-executor.js --headed=false --browsers=chromium,firefox,webkit",
    "heal:file": "node agents/self-healing-executor.js --headed=false --file=",
    "heal:headed": "node agents/self-healing-executor.js --headed=true --file=",
    "ci:install": "npm ci && npx playwright install chromium firefox webkit",
    "ci:install:quick": "npm ci && npx playwright install chromium",
    "ci:mcp:smoke": "node agents/real-executor.js --headed=false --browsers=chromium,firefox --parallel",
    "ci:mcp:regression": "node agents/real-executor.js --headed=false --browsers=chromium,firefox,webkit --parallel",
    "ci:mcp:all": "node agents/real-executor.js --headed=false",
    "ci:mcp:file": "node agents/real-executor.js --headed=false --browsers=chromium,firefox --parallel --file=",
    "ci:smoke": "ts-node agents/executor.ts --suite=smoke --browsers=chromium,firefox --parallel",
    "ci:regression": "ts-node agents/executor.ts --suite=regression --browsers=chromium,firefox,webkit --parallel",
    "ci:single-file": "ts-node agents/executor.ts --file=$FILE --browsers=chromium,firefox --parallel",
    "ci:pim": "ts-node agents/executor.ts --file=verifyPIMPage.txt --browsers=chromium,firefox,webkit --parallel",
    "ci:login": "ts-node agents/executor.ts --file=Login_Datadriven.txt --browsers=chromium,firefox --parallel",
    "ci:employee": "ts-node agents/executor.ts --file=addEmployeeVerification.txt --browsers=chromium,firefox --parallel",
    "ci:buzz": "ts-node agents/executor.ts --file=VerifyBuzzPostVerification.txt --browsers=chromium,firefox --parallel",
    "ci:mcp:pim": "node agents/real-executor.js --headed=false --file=verifyPIMPage.txt",
    "ci:mcp:login": "node agents/real-executor.js --headed=false --file=Login_Datadriven.txt",
    "ci:mcp:employee": "node agents/real-executor.js --headed=false --file=addEmployeeVerification.txt",
    "ci:mcp:buzz": "node agents/real-executor.js --headed=false --file=VerifyBuzzPostVerification.txt",
    "ci:mcp:candidate": "node agents/real-executor.js --headed=false --file=addCandidate.txt",
    "ci:prod": "ts-node agents/executor.ts --suite=smoke --browsers=chromium,firefox --env=prod --parallel",
    "ci:staging": "ts-node agents/executor.ts --suite=regression --browsers=chromium,firefox,webkit --env=staging --parallel",
    "ci:mcp:prod": "node agents/real-executor.js --headed=false --suite=smoke --browsers=chromium,firefox",
    "ci:mcp:staging": "node agents/real-executor.js --headed=false --suite=regression --browsers=chromium,firefox,webkit",
    "smoke": "ts-node agents/executor.ts --suite=smoke --browsers=chromium,firefox --env=prod",
    "smoke:dev": "ts-node agents/executor.ts --suite=smoke --browsers=chromium --env=dev",
    "smoke:staging": "ts-node agents/executor.ts --suite=smoke --browsers=chromium,firefox,webkit --env=staging",
    "smoke:cross-browser": "ts-node agents/executor.ts --suite=smoke --browsers=chromium,firefox,webkit --parallel",
    "smoke:mcp": "node agents/real-executor.js --headed=false --suite=smoke",
    "smoke:mcp:headed": "node agents/real-executor.js --headed=true --suite=smoke",
    "sanity": "ts-node agents/executor.ts --suite=sanity --browsers=chromium --env=prod",
    "sanity:quick": "ts-node agents/executor.ts --suite=sanity --browsers=chromium --timeout=60000",
    "sanity:all-browsers": "ts-node agents/executor.ts --suite=sanity --browsers=chromium,firefox,webkit --parallel",
    "sanity:mcp": "node agents/real-executor.js --headed=false --file=smoke-tests.txt",
    "regression:full": "ts-node agents/executor.ts --suite=regression --browsers=chromium,firefox --env=staging",
    "regression:p1": "ts-node agents/executor.ts --suite=p1 --browsers=chromium,firefox,webkit --parallel",
    "regression:cross-browser": "ts-node agents/executor.ts --suite=regression --browsers=chromium,firefox,webkit,edge --parallel",
    "regression:mcp": "node agents/real-executor.js --headed=false --browsers=chromium,firefox,webkit --parallel",
    "validate": "npx ts-node tools/prompt-validator.ts prompts/",
    "validate:demo": "node tools/validator-demo.js",
    "validate:enterprise": "npx ts-node tools/prompt-validator.ts",
    "validate:file": "npx ts-node tools/prompt-validator.ts",
    "validate:build": "tsc tools/prompt-validator.ts --outDir tools/dist --target es2020 --module commonjs",
    "standards": "echo 'See PROMPTING_STANDARDS.md and QUICK_REFERENCE.md for enterprise guidelines'",
    "test:pre-build": "npm run sanity",
    "test:post-build": "npm run smoke",
    "test:pre-release": "npm run regression:full",
    "test:post-deployment": "npm run smoke && npm run sanity",
    "test:mcp:pre-build": "npm run sanity:mcp",
    "test:mcp:post-build": "npm run smoke:mcp",
    "test:all-browsers": "ts-node agents/executor.ts --browsers=chromium,firefox,webkit --parallel",
    "test:chrome-firefox": "ts-node agents/executor.ts --browsers=chromium,firefox --parallel",
    "test:cross-browser": "ts-node agents/executor.ts --suite=smoke --browsers=chromium,firefox,webkit",
    "test:mcp:all-browsers": "node agents/real-executor.js --headed=false --browsers=chromium,firefox,webkit --parallel",
    "test:mcp:chrome-firefox": "node agents/real-executor.js --headed=false --browsers=chromium,firefox --parallel",
    "test:chrome": "ts-node agents/executor.ts --browsers=chromium --headed",
    "test:firefox": "ts-node agents/executor.ts --browsers=firefox --headed",
    "test:safari": "ts-node agents/executor.ts --browsers=webkit --headed",
    "test:edge": "ts-node agents/executor.ts --browsers=edge --headed",
    "test:mcp:chrome": "node agents/real-executor.js --headed=true --browser=chromium",
    "test:mcp:firefox": "node agents/real-executor.js --headed=true --browser=firefox",
    "test:mcp:safari": "node agents/real-executor.js --headed=true --browser=webkit",
    "test:smoke": "npm run regression -- --tags=smoke",
    "test:p1": "npm run regression -- --tags=P1",
    "test:login": "npm run regression -- --tags=login",
    "test:headed": "ts-node agents/executor.ts --suite=smoke --headed",
    "test:mcp:dev": "node agents/real-executor.js --headed=true --verbose",
    "run:file": "ts-node agents/executor.ts --browsers=chromium,firefox --parallel",
    "run:file:single": "ts-node agents/executor.ts --browsers=chromium",
    "run:file:all": "ts-node agents/executor.ts --browsers=chromium,firefox,webkit --parallel",
    "run:file:headed": "ts-node agents/executor.ts --browsers=chromium --headed",
    "run:mcp:file": "node agents/real-executor.js --headed=false --file=",
    "run:mcp:file:headed": "node agents/real-executor.js --headed=true --file=",
    "dev": "ts-node agents/executor.ts --verbose",
    "test:any": "ts-node agents/executor.ts --browsers=chromium --verbose",
    "dev:mcp": "node agents/real-executor.js --headed=true --verbose",
    "app": "ts-node cli/executor-cli.ts",
    "app:orangehrm": "ts-node cli/executor-cli.ts --app=orangehrm",
    "app:shopify": "ts-node cli/executor-cli.ts --app=shopify",
    "app:generic": "ts-node cli/executor-cli.ts --app=genericweb",
    "app:list": "ts-node cli/executor-cli.ts --list-apps",
    "app:help": "ts-node cli/executor-cli.ts --help",
    "test:orangehrm": "ts-node cli/executor-cli.ts --app=orangehrm --suite=smoke",
    "test:shopify": "ts-node cli/executor-cli.ts --app=shopify --suite=smoke",
    "test:all-apps": "npm run test:orangehrm && npm run test:shopify && npm run test:generic",
    "heal:quick": "node agents/self-healing-executor.js --headed=false --file=smoke-tests.txt",
    "heal:full": "node agents/self-healing-executor.js --headed=false --browsers=chromium,firefox,webkit",
    "heal:debug": "node agents/self-healing-executor.js --headed=true --verbose",
    "clean": "rimraf results/*.* agents/*.js agents/*.d.ts",
    "clean:all": "rimraf results/* node_modules/.cache",
    "setup": "npx playwright install chromium firefox webkit",
    "setup:all": "npx playwright install",
    "setup:deps": "npx playwright install-deps",
    "setup:mcp": "npm install && npx playwright install chromium",
    "results:open": "start results/report.html",
    "results:server": "npx http-server results -p 8080 -o",
    "results:clean": "rimraf results/debug/* results/*.json results/*.html",
    "help": "echo 'Available commands: npm run mcp:smoke, npm run mcp:headed, npm run heal:quick, npm run ci:mcp:smoke'",
    "help:mcp": "echo 'MCP Executor: npm run mcp:file -- --file=yourfile.txt'",
    "help:heal": "echo 'Self-Healing: npm run heal:file -- --file=yourfile.txt'"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.1.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "csv-parser": "^3.0.0",
    "playwright": "^1.59.1",
    "xlsx": "^0.18.5"
  }
}